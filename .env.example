# ─── Yugantar Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in the values.

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-chars-long

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Magic Link) — SMTP provider (e.g., Resend, SendGrid, Gmail)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-smtp-user
EMAIL_SERVER_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yugantar.app

# ─── Anthropic Claude (AI Explanations) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── Vercel (Deployment) ─────────────────────────────────────────────────────
# Automatically set by Vercel; no need to configure manually.
# VERCEL_URL=your-app.vercel.app
